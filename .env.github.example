# ============================================================
# REQUIRED: GitHub env vars/secrets the staging workflow validates explicitly
# ============================================================

# GitHub Secrets: Azure OIDC
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=

# GitHub Secrets: shared staging runtime secrets
STG_DATABASE_URL=
STG_ENTRA_CLIENT_SECRET=
STG_WORKER_INTERNAL_API_TOKEN=
STG_WORKER_HEARTBEAT_TOKEN=

# GitHub Variables: shared Azure target selection
AZ_RESOURCE_GROUP=
AZ_ACR_NAME=
AZ_WEB_APP_NAME=
AZ_WORKER_APP_NAME=

# GitHub Variables: web staging runtime config
STG_ENTRA_TENANT_ID=
STG_ENTRA_CLIENT_ID=
STG_ADMIN_GROUP_ID=
STG_USER_GROUP_ID=
STG_DATAVERSE_BASE_URL=
STG_DATAVERSE_TABLE_URL=
STG_DATAVERSE_COLUMN_PREFIX=cr6c3
STG_INTERNAL_EMAIL_DOMAINS=princeton.edu
STG_DASHBOARD_DORMANT_LOOKBACK_DAYS=90

# GitHub Variables: worker staging runtime config
STG_DB_CONNECT_TIMEOUT_SECONDS=10
STG_SCHEDULER_POLL_SECONDS=30
STG_GRAPH_BASE=https://graph.microsoft.com/v1.0
STG_GRAPH_MAX_CONCURRENCY=4
STG_GRAPH_MAX_RETRIES=5
STG_GRAPH_CONNECT_TIMEOUT=10
STG_GRAPH_READ_TIMEOUT=60
STG_GRAPH_PAGE_SIZE=200
STG_GRAPH_PERMISSIONS_BATCH_SIZE=50
STG_GRAPH_PERMISSIONS_STALE_AFTER_HOURS=24
STG_FLUSH_EVERY=500


# ============================================================
# OPTIONAL: GitHub vars/secrets with workflow fallback behavior
# ============================================================

# GitHub Variables: web URL overrides
# If unset, workflow derives NEXTAUTH URL from the web Container App FQDN.
STG_NEXTAUTH_URL=

# If unset, workflow defaults to "http://${AZ_WORKER_APP_NAME}".
STG_WORKER_API_URL=

# Optional override for Copilot quarantine calls when the web app should skip
# resolving the Power Platform environment from DATAVERSE_BASE_URL.
STG_POWER_PLATFORM_ENVIRONMENT_ID=

# If unset, workflow uses WORKER_HEARTBEAT_URL; if that is also unset,
# it falls back to "https://${web_fqdn}/api/internal/worker-heartbeat".
STG_WORKER_HEARTBEAT_URL=
WORKER_HEARTBEAT_URL=

# Optional: enables the Copilot quarantine mapping table shown on the agent
# access-control page.
STG_DATAVERSE_AGENT_SECURITY_GROUP_MAPPING_TABLE_URL=

# GitHub Variables: worker licensing overrides
STG_LICENSE_PUBLIC_KEY_PATH=
STG_LICENSE_CACHE_TTL_SECONDS=300

# GitHub Variables / Secrets: Application Insights can be supplied with either
# staging-scoped names or shared fallback names used by the worker job.
STG_APPINSIGHTS_APP_ID=
APPINSIGHTS_APP_ID=
STG_APPINSIGHTS_API_KEY=
APPINSIGHTS_API_KEY=
